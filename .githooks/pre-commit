#!/usr/bin/env bash
set -euo pipefail

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"
if [ -z "$staged_files" ]; then
  exit 0
fi

path_check_files="$(printf '%s\n' "$staged_files" | rg -v '(^|/)\.env\.example$' || true)"
if printf '%s\n' "$path_check_files" | rg -q '(^|/)\.env($|\.)|(^|/)aws_credentials($|\.)|(^|/)id_rsa($|\.)|\.pem$|\.key$|\.p12$|\.pfx$'; then
  echo "Blocked commit: staged file path matches secret-bearing patterns." >&2
  exit 1
fi

if git diff --cached -U0 -- . ':(exclude).githooks/pre-commit' ':(exclude).env.example' | rg -n -i \
  -e '^\+.*CATMAPPER_AUTH_SECRET' \
  -e '^\+.*SECRET_KEY' \
  -e '^\+.*AWS_SECRET_ACCESS_KEY' \
  -e '^\+.*AWS_ACCESS_KEY_ID' \
  -e '^\+.*MAIL_PASSWORD' \
  -e '^\+.*NEO4J_PASSWORD' \
  -e '^\+.*api[_-]?key' \
  -e '^\+.*password\s*=' \
  -e '^\+.*passwd\s*=' \
  -e '^\+.*neo4j\.auth\.basic\(' \
  -e '^\+.*createDriver\(' >/dev/null; then
  echo "Blocked commit: staged diff contains potential secrets. Rotate/remove first." >&2
  exit 1
fi
